{
  "name": "@intric/web",
  "version": "1.23.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "NODE_ENV=production vite build",
    "build:all": "bun run --filter @intric/web... build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "test": "bun run test:unit",
    "check": "NODE_ENV=production svelte-kit sync && bun run i18n:compile && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:browsers": "node scripts/ensure-browsers.mjs",
    "pretest:unit": "bun run test:browsers",
    "test:unit": "vitest run",
    "pretest:unit:watch": "bun run test:browsers",
    "test:unit:watch": "vitest",
    "pretest:e2e": "bun run test:browsers",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:integration": "bun run test:e2e",
    "test:all": "bun run test:unit && bun run test:e2e",
    "pretest:coverage": "bun run test:browsers",
    "test:coverage": "vitest run --coverage",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@internationalized/date": "^3.12.0",
    "@intric/eslint-plugin": "workspace:*",
    "@intric/intric-js": "workspace:*",
    "@lucide/svelte": "^1.11.0",
    "@melt-ui/svelte": "^0.86.5",
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.20.5",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.14.0",
    "@types/wicg-file-system-access": "^2023.10.6",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "bits-ui": "^2.16.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-svelte": "^3.5.1",
    "globals": "^16.0.0",
    "mode-watcher": "^1.1.0",
    "playwright": "1.58.2",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "svelte": "^5.25.12",
    "svelte-check": "^4.1.5",
    "svelte-headless-table": "^0.18.3",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "uid": "^2.0.2",
    "vite": "^6.4.1",
    "vitest": "3.2.4",
    "vitest-browser-svelte": "^1.1.0"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.0.13",
    "@intric/ui": "workspace:*",
    "lucide-svelte": "^0.544.0"
  }
}
